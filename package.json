{
  "name": "buildflow-monorepo",
  "private": true,
  "scripts": {
    "build:backend": "npm --prefix ./apps/backend run build",
    "test:unit": "cd apps/frontend && npx jest --coverage",
    "test:e2e": "cd apps/frontend && npx playwright test",
    "audit": "npm audit --omit=dev",
    "ci": "npm run audit && npm run test:unit && npm run test:e2e"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "babel-jest": "^30.3.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "next-themes": "^0.4.6",
    "tailwind-merge": "^3.5.0"
  }
}
